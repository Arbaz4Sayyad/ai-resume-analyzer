# Database
DATABASE_URL=jdbc:postgresql://postgres:5432/airesumeanalyzer
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (generate: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# AI Service - Google Gemini (required for resume analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI (legacy, if used)
OPENAI_API_KEY=sk-your_openai_api_key_here

# AI Service URL (backend calls this)
AI_SERVICE_URL=http://localhost:8000

# CORS (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth - GitHub
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OAuth - Facebook
FACEBOOK_CLIENT_ID=your_facebook_client_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret_here

# Frontend / Backend public URLs (used for redirects, CORS, etc.)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# SMTP / Email (for forgot-password)
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
